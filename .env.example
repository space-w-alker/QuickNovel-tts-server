PORT=3000
HOST=0.0.0.0
PUBLIC_BASE_URL=https://quicknovel-140-238-89-232.sslip.io
DATA_DIR=./data

# Generate independent random values of at least 32 bytes for production.
ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
AUDIO_SIGNING_SECRET=replace-with-another-long-random-secret
ACCESS_TOKEN_TTL_SECONDS=3600
AUDIO_URL_TTL_SECONDS=900
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute

# Dokploy: set this to a unique password (12+ characters). The username defaults to superadmin.
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=replace-with-a-unique-admin-password
ADMIN_SESSION_TTL_SECONDS=43200
ADMIN_SECURE_COOKIE=true

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=QuickNovel

# Optional JSON override for the built-in Standard, High and Ultra catalog.
# Keep public model/voice IDs stable and bump cacheRevision whenever synthesis output can change.
TTS_MODELS_JSON=
MAX_CHUNK_CHARACTERS=4000
MAX_AUDIO_BYTES=52428800
DAILY_CHARACTER_QUOTA=100000
DAILY_GENERATION_QUOTA=1000
