PORT=3000
HOST=0.0.0.0
PUBLIC_BASE_URL=http://localhost:3000
DATA_DIR=./data

# Generate independent random values of at least 32 bytes for production.
ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
AUDIO_SIGNING_SECRET=replace-with-another-long-random-secret
ACCESS_TOKEN_TTL_SECONDS=3600
AUDIO_URL_TTL_SECONDS=900
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=QuickNovel

TTS_MODEL_ID=quicknovel-default
TTS_MODEL_DISPLAY_NAME=QuickNovel Voice
TTS_OPENROUTER_MODEL=openai/gpt-4o-mini-tts-2025-12-15
TTS_MODEL_CACHE_REVISION=openai/gpt-4o-mini-tts-2025-12-15@1
TTS_VOICES=alloy:Alloy:en-US,nova:Nova:en-US
MAX_CHUNK_CHARACTERS=4000
MAX_AUDIO_BYTES=52428800
DAILY_CHARACTER_QUOTA=100000
DAILY_GENERATION_QUOTA=1000
