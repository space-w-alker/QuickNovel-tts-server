<header class="topbar"><div><div class="eyebrow">Runtime inventory</div><h1>System</h1><p class="subtitle">Non-secret deployment configuration, process health and persistence footprint.</p></div><div class="top-actions"><a class="button" href="/health" target="_blank" rel="noreferrer">Open health endpoint</a></div></header>
<section class="grid two-col"><article class="card"><div class="card-head"><div><h2>Process & storage</h2></div></div><div class="card-body kv"><div class="key">Environment</div><div>{{system.environment}}</div><div class="key">Node.js</div><div class="mono">{{system.node}}</div><div class="key">Process uptime</div><div>{{number system.uptimeSeconds}} seconds</div><div class="key">Resident memory</div><div>{{bytes system.rssBytes}}</div><div class="key">Heap used</div><div>{{bytes system.heapUsedBytes}}</div><div class="key">SQLite allocation</div><div>{{bytes system.databaseBytes}}</div><div class="key">Data directory</div><div class="mono">{{system.dataDir}}</div><div class="key">Secure admin cookie</div><div><span class="status {{#if system.secureCookie}}status-ready{{else}}status-warning{{/if}}">{{#if system.secureCookie}}enabled{{else}}disabled{{/if}}</span></div></div></article>
<article class="card"><div class="card-head"><div><h2>Service configuration</h2></div></div><div class="card-body kv"><div class="key">Public URL</div><div class="mono">{{system.publicBaseUrl}}</div><div class="key">OpenRouter key</div><div><span class="status {{#if system.openRouterConfigured}}status-ready{{else}}status-failed{{/if}}">{{#if system.openRouterConfigured}}configured{{else}}missing{{/if}}</span></div><div class="key">Global rate limit</div><div>{{system.rateLimit}}</div><div class="key">Access token TTL</div><div>{{number system.accessTokenTtlSeconds}} seconds</div><div class="key">Signed audio URL TTL</div><div>{{number system.audioUrlTtlSeconds}} seconds</div></div></article></section>
<article class="card" style="margin-top:16px"><div class="card-head"><div><h2>Configured quality presets</h2></div></div><div class="table-wrap"><table><thead><tr><th>Quality</th><th>Provider model</th><th>Provider format</th><th>Cache revision</th><th>Voices</th></tr></thead><tbody>{{#each system.models}}<tr><td>{{displayName}} <span class="muted mono">{{id}}</span></td><td class="mono">{{openRouterModel}}</td><td>{{providerAudioFormat}} → mp3</td><td class="mono">{{cacheRevision}}</td><td>{{#each voices}}{{displayName}} <span class="muted mono">({{providerVoice}})</span>{{#unless @last}} · {{/unless}}{{/each}}</td></tr>{{/each}}</tbody></table></div></article>
