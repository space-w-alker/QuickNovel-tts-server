<header class="topbar"><div><div class="eyebrow">Investigation timeline</div><h1>Events & errors</h1><p class="subtitle">Generation outcomes, server failures, authentication warnings and an audit trail of every admin change.</p></div><div class="top-actions"><a class="button" href="/admin/events">Refresh</a></div></header>
<article class="card"><div class="table-wrap"><table><thead><tr><th>Time UTC</th><th>Level</th><th>Category</th><th>Event</th><th>Message & context</th></tr></thead><tbody>{{#each events}}<tr><td class="muted">{{date createdAt}}</td><td><span class="status status-{{severity}}">{{severity}}</span></td><td>{{category}}</td><td class="mono">{{action}}</td><td><strong>{{message}}</strong>{{#if contextDisplay}}<details><summary class="muted">Context</summary><pre>{{contextDisplay}}</pre></details>{{/if}}</td></tr>{{else}}<tr><td colspan="5" class="empty">No events have been recorded.</td></tr>{{/each}}</tbody></table></div></article>
