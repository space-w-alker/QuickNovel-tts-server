<header class="topbar"><div><div class="eyebrow">Generated media</div><h1>Audio library</h1><p class="subtitle">Play, download, inspect and remove every cached audio asset.</p></div><div class="top-actions"><a class="button" href="/admin/generation-requests">View cache outcomes</a>{{#if (eq status 'failed')}}<form method="post" action="/admin/audio/clear-failed" onsubmit="return confirm('Clear every failed job record? Clients will be able to request them again.');"><input type="hidden" name="csrf_token" value="{{csrfToken}}"><button class="danger" type="submit">Clear failed records</button></form>{{/if}}</div></header>
{{#if notice}}<div class="notice">{{notice}}</div>{{/if}}
<section class="grid metrics">
  <article class="metric"><div class="label">Total audio size</div><div class="value">{{bytes metrics.totalBytes}}</div><div class="detail">Stored ready audio on the server</div></article>
  <article class="metric"><div class="label">Audio records</div><div class="value">{{number metrics.totalRecords}}</div><div class="detail">{{number metrics.ready}} ready · {{number metrics.generating}} generating · {{number metrics.failed}} failed</div></article>
  <article class="metric"><div class="label">Tracked requests</div><div class="value">{{number metrics.trackedRequests}}</div><div class="detail">Preserved even when audio is deleted</div></article>
  <article class="metric"><div class="label">Cache outcomes</div><div class="value">{{number metrics.cacheHits}} hits</div><div class="detail">{{number metrics.cacheMisses}} misses</div></article>
</section>
<div class="filters" style="margin-bottom:14px"><a class="filter {{#if (eq status 'all')}}active{{/if}}" href="{{allStatusUrl}}">All</a><a class="filter {{#if (eq status 'ready')}}active{{/if}}" href="{{readyStatusUrl}}">Ready</a><a class="filter {{#if (eq status 'generating')}}active{{/if}}" href="{{generatingStatusUrl}}">Generating</a><a class="filter {{#if (eq status 'failed')}}active{{/if}}" href="{{failedStatusUrl}}">Failed</a></div>
<article class="card"><div class="table-wrap"><table><thead><tr><th><a class="sort-link" href="{{updatedSortUrl}}">Updated UTC <span aria-hidden="true">{{updatedSortIndicator}}</span></a></th><th>Status / audio</th><th>Identity</th><th>Provider / voice / input</th><th><a class="sort-link" href="{{cacheHitsSortUrl}}">Requests / cache hits <span aria-hidden="true">{{cacheHitsSortIndicator}}</span></a></th><th><a class="sort-link" href="{{sizeSortUrl}}">Size / error <span aria-hidden="true">{{sizeSortIndicator}}</span></a></th><th>Manage</th></tr></thead><tbody>{{#each audio}}<tr><td class="muted">{{date updatedAt}}</td><td><span class="status status-{{status}}">{{status}}</span>{{#if playbackUrl}}<audio class="player" controls preload="none" src="{{playbackUrl}}">Audio playback is unavailable in this browser.</audio>{{/if}}</td><td><div class="mono" title="Cache key: {{cacheKey}}">cache {{short cacheKey}}</div><div class="muted mono" title="Job ID: {{jobId}}">job {{short jobId}}</div></td><td>{{providerId}} · {{generationSource}}<div>{{voiceId}} · {{number inputCharacters}} chars</div><div class="muted mono">{{modelId}}</div></td><td>{{number requestCount}} tracked<div><span class="ok-text">{{number cacheHits}} hits</span> · <span class="muted">{{number cacheMisses}} misses</span></div></td><td>{{bytes bytes}}{{#if errorCode}}<div class="danger-text">{{errorCode}}</div><div class="muted">{{errorMessage}}</div>{{/if}}</td><td><div class="inline-actions">{{#if playbackUrl}}<a class="button" href="{{playbackUrl}}" download>Download</a>{{/if}}{{#unless (eq status 'generating')}}<form method="post" action="/admin/audio/{{cacheKey}}/delete" onsubmit="return confirm('Delete this cached audio file and metadata? Request history will remain, but clients will regenerate it next time.');"><input type="hidden" name="csrf_token" value="{{../csrfToken}}"><button class="danger" type="submit">Delete</button></form>{{/unless}}</div></td></tr>{{else}}<tr><td colspan="7" class="empty">No audio records match this filter.</td></tr>{{/each}}</tbody></table></div><div class="pagination"><span>{{number total}} audio records · page {{page}} of {{totalPages}}</span><div class="pagination-links">{{#if hasPrevious}}<a class="button" href="{{previousUrl}}">Previous</a>{{/if}}{{#if hasNext}}<a class="button" href="{{nextUrl}}">Next</a>{{/if}}</div></div></article>
