<header class="topbar"><div><div class="eyebrow">Client management</div><h1>Installations</h1><p class="subtitle">Review registered clients and today's quota consumption. Reset usage or revoke credentials when needed.</p></div></header>
{{#if notice}}<div class="notice">{{notice}}</div>{{/if}}
<div class="callout">Revoking an installation permanently invalidates its refresh token. The client must register again. Reset usage affects only today's quota counters.</div>
<article class="card"><div class="table-wrap"><table><thead><tr><th>Registered UTC</th><th>Installation ID</th><th>Characters today</th><th>Generations today</th><th>Controls</th></tr></thead><tbody>{{#each installations}}<tr><td class="muted">{{date createdAt}}</td><td class="mono">{{id}}</td><td>{{number characters}}</td><td>{{number generations}}</td><td><div class="inline-actions"><form method="post" action="/admin/installations/{{id}}/reset-usage" onsubmit="return confirm('Reset today’s quota usage for this installation?');"><input type="hidden" name="csrf_token" value="{{../csrfToken}}"><button type="submit">Reset usage</button></form><form method="post" action="/admin/installations/{{id}}/revoke" onsubmit="return confirm('Permanently revoke this installation and its refresh token?');"><input type="hidden" name="csrf_token" value="{{../csrfToken}}"><button class="danger" type="submit">Revoke</button></form></div></td></tr>{{else}}<tr><td colspan="5" class="empty">No installations have registered.</td></tr>{{/each}}</tbody></table></div></article>
