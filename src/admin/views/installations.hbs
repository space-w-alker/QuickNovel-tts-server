<header class="topbar"><div><div class="eyebrow">Client management</div><h1>Installations</h1><p class="subtitle">Approve backend generation, review quota consumption, suspend access, or revoke credentials.</p></div></header>
{{#if notice}}<div class="notice">{{notice}}</div>{{/if}}
<div class="callout">Pending and suspended clients can use cache hits and BYOK uploads, but only approved clients can start server-funded generation. Revocation permanently invalidates credentials.</div>
<article class="card"><div class="table-wrap"><table><thead><tr><th>Registered UTC</th><th>Installation ID</th><th>Backend status</th><th>Usage today</th><th>Controls</th></tr></thead><tbody>{{#each installations}}<tr><td class="muted">{{date createdAt}}</td><td class="mono">{{id}}</td><td><span class="status status-{{backendGenerationStatus}}">{{backendGenerationStatus}}</span><div class="muted">{{date statusUpdatedAt}}</div></td><td>{{number characters}} chars · {{number generations}} generations</td><td><div class="inline-actions">{{#unless (eq backendGenerationStatus 'approved')}}<form method="post" action="/admin/installations/{{id}}/approve"><input type="hidden" name="csrf_token" value="{{../csrfToken}}"><button type="submit">Approve</button></form>{{/unless}}{{#if (eq backendGenerationStatus 'approved')}}<form method="post" action="/admin/installations/{{id}}/suspend"><input type="hidden" name="csrf_token" value="{{../csrfToken}}"><button type="submit">Suspend</button></form>{{/if}}<form method="post" action="/admin/installations/{{id}}/reset-usage"><input type="hidden" name="csrf_token" value="{{../csrfToken}}"><button type="submit">Reset usage</button></form><form method="post" action="/admin/installations/{{id}}/revoke" onsubmit="return confirm('Permanently revoke this installation and its refresh token?');"><input type="hidden" name="csrf_token" value="{{../csrfToken}}"><button class="danger" type="submit">Revoke</button></form></div></td></tr>{{else}}<tr><td colspan="5" class="empty">No installations have registered.</td></tr>{{/each}}</tbody></table></div></article>
