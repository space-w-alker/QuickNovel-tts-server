<header class="topbar"><div><div class="eyebrow">Live service picture</div><h1>Operations overview</h1><p class="subtitle">API traffic, generation throughput and storage health at a glance.</p></div><div class="top-actions"><span class="status {{#if settings.generationEnabled}}status-ready{{else}}status-failed{{/if}}">Generation {{#if settings.generationEnabled}}active{{else}}paused{{/if}}</span><a class="button" href="/admin/overview">Refresh</a></div></header>
{{#if notice}}<div class="notice">{{notice}}</div>{{/if}}
<section class="grid metrics">
  <article class="metric"><div class="label">Requests · 24h</div><div class="value">{{number overview.requests24h}}</div><div class="detail">{{number overview.errors24h}} client/server errors</div></article>
  <article class="metric"><div class="label">Latency · average</div><div class="value">{{duration overview.averageLatencyMs}}</div><div class="detail">p95 {{duration overview.p95LatencyMs}}</div></article>
  <article class="metric"><div class="label">Generations · today</div><div class="value">{{number overview.todayGenerations}}</div><div class="detail">{{number overview.todayCharacters}} characters</div></article>
  <article class="metric"><div class="label">Cached audio</div><div class="value">{{number overview.readyAudio}}</div><div class="detail">{{bytes overview.cachedBytes}} on record</div></article>
  <article class="metric"><div class="label">Installations</div><div class="value">{{number overview.installations}}</div><div class="detail">{{number overview.approvedInstallations}} approved · {{number overview.pendingInstallations}} pending · {{number overview.suspendedInstallations}} suspended</div></article>
  <article class="metric"><div class="label">Generating</div><div class="value">{{number overview.generatingAudio}}</div><div class="detail">Jobs currently claimed</div></article>
  <article class="metric"><div class="label">Failed jobs</div><div class="value {{#if overview.failedAudio}}danger-text{{/if}}">{{number overview.failedAudio}}</div><div class="detail">Retained for investigation</div></article>
  <article class="metric"><div class="label">Cache outcomes · 24h</div><div class="value">{{number overview.cacheHits24h}} hits</div><div class="detail">{{number overview.cacheMisses24h}} misses · <a class="ok-text" href="/admin/generation-requests">view every request</a></div></article>
</section>
<section class="grid two-col">
  <article class="card"><div class="card-head"><div><h2>Recent API trace</h2><p>Latest client-facing requests; admin traffic is excluded.</p></div><a class="button" href="/admin/requests">View all</a></div><div class="table-wrap"><table><thead><tr><th>Time UTC</th><th>Request</th><th>Status</th><th>Latency</th></tr></thead><tbody>{{#each requests}}<tr><td class="muted">{{date createdAt}}</td><td><span class="mono">{{method}}</span> {{path}}</td><td><span class="status status-{{statusCode}}">{{statusCode}}</span></td><td>{{duration durationMs}}</td></tr>{{else}}<tr><td colspan="4" class="empty">Requests will appear here as clients use the API.</td></tr>{{/each}}</tbody></table></div></article>
  <article class="card"><div class="card-head"><div><h2>Operational events</h2><p>Admin actions and generation outcomes.</p></div><a class="button" href="/admin/events">Explore</a></div><div class="card-body event-list">{{#each events}}<div class="event"><span class="event-dot {{severity}}"></span><div><strong>{{message}}</strong><p>{{category}} · {{action}}</p></div><time>{{date createdAt}}</time></div>{{else}}<div class="empty">No operational events recorded yet.</div>{{/each}}</div></article>
</section>
