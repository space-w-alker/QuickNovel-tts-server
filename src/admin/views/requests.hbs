<header class="topbar"><div><div class="eyebrow">Traceability</div><h1>Request trace</h1><p class="subtitle">The latest 250 API requests with identifiers, caller context, status and end-to-end latency.</p></div><div class="top-actions"><a class="button" href="/admin/requests">Refresh</a></div></header>
<article class="card"><div class="table-wrap"><table><thead><tr><th>Time UTC</th><th>Request ID</th><th>Route</th><th>Status</th><th>Latency</th><th>Installation</th><th>Caller</th></tr></thead><tbody>{{#each requests}}<tr><td class="muted">{{date createdAt}}</td><td class="mono" title="{{requestId}}">{{short requestId}}</td><td><span class="mono">{{method}}</span> {{path}}</td><td><span class="status status-{{statusCode}}">{{statusCode}}</span></td><td>{{duration durationMs}}</td><td class="mono" title="{{installationId}}">{{short installationId}}</td><td><span title="{{userAgent}}">{{ip}}</span></td></tr>{{else}}<tr><td colspan="7" class="empty">No API requests have been recorded.</td></tr>{{/each}}</tbody></table></div></article>
